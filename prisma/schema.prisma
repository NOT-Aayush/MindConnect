generator client {
  provider = "prisma-client-js"
}

datasource db {
provider = "postgresql"
url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  city      String?
  role      UserRole @default(PATIENT)
  password  String
  createdAt DateTime @default(now())
  bookings  Booking[]
}

model Doctor {
  id              String   @id @default(cuid())
  name            String
  city            String
  specialty       String
  experienceYears Int
  background      String
  feesINR         Int
  languages       String
  rating          Float    @default(4.5)
  avatarUrl       String?
  freeSlots       FreeSlot[]
  bookings        Booking[]  // Added this line to fix the relation
  createdAt       DateTime @default(now())
}

model FreeSlot {
  id        String   @id @default(cuid())
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  doctorId  String
  start     DateTime
  end       DateTime
}

model Booking {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  doctorId  String
  slotStart DateTime
  slotEnd   DateTime
  createdAt DateTime @default(now())
}

model Blog {
  id        String   @id @default(cuid())
  title     String
  excerpt   String
  content   String
  author    String
  role      String
  cover     String?
  createdAt DateTime @default(now())
}

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
}